  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#毛蓬蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#云南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#广西壮族自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#湖北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#贵州省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#清热消炎祛风利湿"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶卵形椭圆状卵形或近圆形二至三回栉齿状羽状分裂小裂片细小近椭圆形长1_2mm宽0_2_0_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#球形或半球形直径2_5_3_5_4mm有短梗或近无梗下垂排成总状花序复总状花序或近似穗状花序在茎上组成开展或略开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_vestita_Wall_ex_Bess"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根木质稍粗根状茎粗短木质直径0_5_2cm常有营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本或小灌木状"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#叶面绿色或灰绿色有小凹穴两面被灰白色密绒毛或上面毛略少背面毛密"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#小凸起"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花6_10朵花冠狭管状檐部2裂齿两性花13_20朵孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长外层卵状披针形或长卵形背面被灰白色短柔毛中肋明显绿色边缘狭膜质中内层卵形或宽卵形背面微有短柔毛边缘宽膜质内层膜质背面无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>毛蓬蒿</art:中文名>
    <rdfs:label>毛蓬蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#头状花序较大直径4_5_7mm总苞片开花后成放射状开张花易于脱落">
