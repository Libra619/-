    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层背面无毛或近无毛有绿色中肋外层草质椭圆形边狭膜质中内层稍大卵形具宽膜质边缘或全膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
