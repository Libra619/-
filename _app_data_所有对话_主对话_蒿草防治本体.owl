    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#吉林省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#天津市"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#宁夏回族自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#安徽省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山东省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#广东省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#广西壮族自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#江苏省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#江西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#浙江省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#海南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#湖北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#湖南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#福建省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#贵州省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#重庆市"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#陕西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#作_艾_代用品清热解毒止血消炎"/>
    <art:包含成分 rdf:resource="http://www.example.org/ontology/Artemisia#含挥发油桉叶油素苦艾素倍半萜烯醇侧柏酮等"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶一至二回羽状全裂或大头羽状深裂裂片椭圆状披针形"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序卵形直径2_2_5毫米"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_indica"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根状茎稍粗短"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本或半灌木"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面初时被灰白色绒毛后无毛下面密被灰白色蛛丝状绒毛"/>
    <art:致敏物质是 rdf:resource="http://www.example.org/ontology/Artemisia#花粉"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#小凸起无托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花4_8朵两性花8_12朵均结实"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片背面初时微被绒毛后无毛中脉绿色"/>
    <art:造成危害 rdf:resource="http://www.example.org/ontology/Artemisia#过敏性鼻炎"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#蒿属"/>
    <art:中文名>五月艾</art:中文名>
    <rdfs:label>五月艾</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#西北蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#宁夏回族自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶二回羽状全裂小裂片细小椭圆形或短线形宽0_5_1mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#近球形直径2_5_3_3_5mm具短梗或近无梗有小苞叶下垂排成穗状花序在茎上组成狭窄或中等开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_pontica_Linn"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根木质垂直根状茎稍粗大木质直径1_2cm常有营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面疏被灰白色微柔毛背面密被灰绿色柔毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_12朵花冠狭管状或狭圆锥状两性花30_40朵孕育花冠管状檐部外面无毛或微被细短柔毛背面具腺点"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层与中层卵形或长卵形背面被灰白色或灰绿色短柔毛具绿色中肋边膜质内层长卵形或倒卵状长圆形半膜质背面毛少或近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>西北蒿</art:中文名>
    <rdfs:label>西北蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#总苞片3_4层内外层近等长外层椭圆状披针形革质外面被灰白色短柔毛边缘狭膜质褐色中内层卵圆形边缘宽膜质褐色或全膜质">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#总苞片特征"/>
    <rdfs:label>总苞片3-4层内外层近等长，外层椭圆状披针形革质外面被灰白色短柔毛边缘狭膜质褐色，中内层卵圆形边缘宽膜质褐色或全膜质</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#幼时被灰白色短柔毛后脱落">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
