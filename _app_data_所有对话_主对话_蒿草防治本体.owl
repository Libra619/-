    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#作_奇蒿_代用品清热解毒止咳消炎活血散瘀通经治肝肾疾病血丝虫病"/>
    <art:包含成分 rdf:resource="http://www.example.org/ontology/Artemisia#含挥发油黄酮苷酚类氨基酸香豆素等"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶二回或一至二回羽状全裂裂片形状变化大"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序长圆形直径1_5_2_5毫米"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_lactiflora"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根状茎短"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面初时疏被短柔毛或腺毛状短柔毛后无毛"/>
    <art:致敏物质是 rdf:resource="http://www.example.org/ontology/Artemisia#花粉"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花3_6朵两性花4_10朵均结实"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片全为半膜质或膜质背面无毛亦无绿色中肋"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#白苞蒿组"/>
    <art:中文名>白苞蒿</art:中文名>
    <rdfs:label>白苞蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#主根略粗木质垂直侧根多根状茎木质直径0_5_1cm或更粗具多枚营养枝">
