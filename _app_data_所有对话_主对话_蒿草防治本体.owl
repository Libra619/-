    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶一至二回羽状分裂小裂片披针形或线形"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序椭圆形直径1_5_2毫米"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_mongolica"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根状茎稍粗"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面初时被蛛丝状柔毛后近无毛下面密被蛛丝状绒毛"/>
    <art:致敏物质是 rdf:resource="http://www.example.org/ontology/Artemisia#花粉"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花5_10朵两性花8_15朵均结实"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片背面密被蛛丝状毛"/>
    <art:造成危害 rdf:resource="http://www.example.org/ontology/Artemisia#过敏性鼻炎"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#蒿属"/>
    <art:中文名>蒙古蒿</art:中文名>
    <rdfs:label>蒙古蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长外层长卵形背面近无毛边褐色膜质中内层长卵形或卵形无毛边缘褐色宽膜质或全膜质">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#总苞片特征"/>
    <rdfs:label>总苞片3-4层内层近等长，外层长卵形背面近无毛边褐色膜质，中内层长卵形或卵形无毛边缘褐色宽膜质或全膜质</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#藏腺毛蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶长卵形一至二回羽状分裂第一回深裂每侧裂片3_4枚第二回浅裂每侧具2_3枚浅裂齿中轴具明显翅"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#长圆形或长卵形直径2_5_3_4mm无梗排成穗状花序在茎上组成中等开展或开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_thellungiana_Pamp"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根细多枚垂直根状茎小"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面具腺点及小凹点背面被平贴短柔毛脉上具短腺毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_15朵花冠狭圆锥状檐部2_3裂齿两性花16_20朵孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外中层卵形或长卵形背面初时被短柔毛后渐稀疏近无毛具绿色中肋边膜质内层长卵形半膜质无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#多花蒿系"/>
    <art:中文名>藏腺毛蒿</art:中文名>
    <rdfs:label>藏腺毛蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#适用苗龄">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/ontology/Artemisia#防治技术"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>如：2-5叶期、全生育期</rdfs:comment>
    <rdfs:label>适用苗龄</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#Artemisia_chienshanica_Ling_et_W_Wang">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#拉丁名"/>
    <rdfs:label>Artemisia chienshanica Ling et W. Wang</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#中南蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#福建省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶羽状全裂裂片线形"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序小椭圆形直径1_5_2毫米"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_simulans"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根状茎短"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面疏被粘质腺毛或近无毛下面被蛛丝状绒毛及疏腺毛"/>
    <art:致敏物质是 rdf:resource="http://www.example.org/ontology/Artemisia#花粉腺毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花3_5朵两性花8_15朵均结实"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片背面微被蛛丝状绒毛"/>
