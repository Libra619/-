    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部叶长卵形或长圆形二回羽状全裂小裂片披针形或线状披针形宽3_3_5_4mm中部叶与上部叶长卵形一至二回羽状深裂或几全裂"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#宽卵形或钟形直径3_5_4mm无梗或有极短梗下垂单生或2_3枚集生排成穗状花序在茎上组成狭窄或中等开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_sinensis_Pamp_Ling_et_Y_R_Ling"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根粗木质侧根多根状茎木质粗直径5_15mm斜向上或直立"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面初时被稀疏短柔毛及短腺毛状柔毛后脱落近无毛背面初时密被蛛丝状短柔毛后稍稀疏"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_15朵花冠狭管状檐部2裂齿两性花15_25_30朵孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层稍短小外中层卵形或长卵形背面被淡黄色疏短柔毛中肋绿色边膜质内层长卵形或长圆状倒卵形半膜质背面近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#南方大头蒿系"/>
    <art:中文名>西南圆头蒿</art:中文名>
    <rdfs:label>西南圆头蒿</rdfs:label>
  </rdf:Description>
