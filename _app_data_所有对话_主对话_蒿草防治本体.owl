    <rdfs:label>亮绿蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#山艾">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#台湾省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#基生叶卵形或宽卵形莲座状二回羽状全裂茎下部与中部叶长圆形或椭圆形一至二回羽状全裂每侧具3_4枚裂片小裂片线形或线状披针形宽0_5_1_2mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形或宽卵形直径4_4_5mm具短梗2_20mm偏一侧生长花后下垂在茎端或在短的分枝上8_12枚排成疏散总状花序在茎上部组成狭窄疏散总状花序式圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_kawakamii_Hayata"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根稍肥厚长狭纺锤形侧根细少根状茎稍肥大直径0_5_1_5cm黑色常有多枝基生叶叶柄残基"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面初时被绢质绒毛后渐稀疏背面密被白色绵毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_12朵花冠狭管状檐部2_3裂齿两性花18_25朵孕育花冠管状檐部外反"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3层内层近等长外中层卵形背面多少被绵毛边缘膜质褐红色内层倒卵状楔形淡红色边缘宽膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#南方大头蒿系"/>
    <art:中文名>山艾</art:中文名>
    <rdfs:label>山艾</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#雌花8_12朵花冠狭管状或狭圆锥状两性花30_40朵孕育花冠管状檐部外面无毛或微被细短柔毛背面具腺点">
