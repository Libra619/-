    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层略小卵形背面无毛中肋绿色边缘狭膜质中内层长圆形边缘宽膜质或全半膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#旱蒿系"/>
