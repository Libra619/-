  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#光沙蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#吉林省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶宽卵形或近圆形二回羽状全裂每侧裂片2_3枚小裂片狭线形宽1_5_2mm先端锐尖有硬尖头"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#长卵形直径1_5_2_5_3_5mm具短梗2_4mm或近无梗排成穗状花序式总状或复总状花序在茎上组成疏松开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_oxycephala_Kitag"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根木质粗长根状茎稍粗短木质具多数营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本或小灌木状"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#叶厚纸质干时质硬两面无毛或幼时微有短柔毛后无毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_14朵花冠狭圆锥状或狭管状两性花3_10朵不孕育花冠管状外面有腺点花柱短先端棒形2裂不叉开"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外中层卵形或长卵形背面具绿色中肋无毛边膜质内层长卵形或椭圆形半膜质先端钝"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#旱蒿系"/>
    <art:中文名>光沙蒿</art:中文名>
    <rdfs:label>光沙蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#雌花8_12朵花冠狭圆锥状两性花25_35朵孕育花冠管状">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#花结构与育性"/>
    <rdfs:label>雌花8-12朵，花冠狭圆锥状；两性花25-35朵孕育，花冠管状</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#总苞片3层外层略短小外中层卵形或长卵形背面无毛淡黄绿色具绿色中肋边宽膜质内层长卵形或长卵状倒披针形半膜质">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#总苞片特征"/>
    <rdfs:label>总苞片3层，外层略短小，外中层卵形或长卵形背面无毛淡黄绿色具绿色中肋边宽膜质，内层长卵形或长卵状倒披针形半膜质</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#球形或半球形直径2_5_3_5_4mm有短梗或近无梗下垂排成总状花序复总状花序或近似穗状花序在茎上组成开展或略开展圆锥花序">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#头状花序特征"/>
    <rdfs:label>球形或半球形，直径2.5-3.5(-4)mm，有短梗或近无梗下垂，排成总状花序、复总状花序或近似穗状花序，在茎上组成开展或略开展圆锥花序</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#主根粗大木质垂直伸长根状茎粗短直径达2_4cm上部常分化出若干部分有多数营养枝">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#根状茎特征"/>
    <rdfs:label>主根粗大木质垂直伸长；根状茎粗短直径达2-4cm，上部常分化出若干部分，有多数营养枝</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长外层长卵形背面有绿色中肋疏被灰黄色短柔毛边宽膜质中层卵形背面近无毛边宽膜质内层长椭圆形半膜质或膜质无毛">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#总苞片特征"/>
    <rdfs:label>总苞片3-4层内层近等长，外层长卵形背面有绿色中肋疏被灰黄色短柔毛边宽膜质，中层卵形背面近无毛边宽膜质，内层长椭圆形半膜质或膜质无毛</rdfs:label>
  </rdf:Description>
