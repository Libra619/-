  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#基生叶与茎下部叶卵形二至三回羽状全裂每侧裂片3_5枚小裂片披针形或线状披针形长3_5mm宽0_5_1mm中部与上部叶卵形一至二回羽状深裂或全裂小裂片狭线形或狭线状披针形">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#叶形态与分裂"/>
