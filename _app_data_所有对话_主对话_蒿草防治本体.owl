    <art:严重阈值>8.5</art:严重阈值>
    <art:指标单位>无</art:指标单位>
    <art:正常范围上限>7.5</art:正常范围上限>
    <art:正常范围下限>6.5</art:正常范围下限>
    <art:预警阈值>8.0</art:预警阈值>
    <rdfs:label>土壤pH值</rdfs:label>
  </rdf:Description>
