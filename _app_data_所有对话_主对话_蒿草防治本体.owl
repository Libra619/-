  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#垫型蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶近圆形扇形或肾形二回羽状全裂小裂片披针形或长椭圆状披针形宽0_5_1mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形或近球形直径3_5_10mm有短梗或近无梗排成穗状花序式总状花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_minor_Jacq_ex_Bess"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根木质粗垂直根状茎粗大木质黑色直径2_4_5cm上面常具多数短小老茎残基及多数短营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#垫状半灌木状草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#茎枝叶两面及总苞片背面密被灰白色或淡灰黄色平贴丝状绵毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形密生白色托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_18朵花冠瓶状或狭圆锥状檐部2_3_4裂齿紫色两性花50_80朵孕育花冠管状檐部紫色"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层略长于外层外层与中层卵形或长卵形边缘宽膜质紫色内层椭圆形半膜质或膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>垫型蒿</art:中文名>
    <rdfs:label>垫型蒿</rdfs:label>
  </rdf:Description>
