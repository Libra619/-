  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#藏东蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶椭圆形或长圆形二回羽状分裂第一回全裂每侧裂片4_5枚每侧具2_3枚深裂齿或浅裂齿裂齿长3_4mm宽1_1_5_2mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#宽卵形或钟形直径3_4_5mm无梗或有短梗排成密集穗状或穗状花序式总状花序在茎上组成狭窄圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_vexans_Pamp"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根稍粗木质侧根多根状茎短直立或斜向上木质"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本或半灌木状"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面被腺毛初时叶上面还被绒毛以后脱落背面密被淡灰黄色或灰白色蛛丝状绒毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_10朵花冠狭管状檐部2_3裂齿两性花30_40_50朵孕育花冠管状檐部紫色"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长边缘具须毛外中层卵形或长卵形背面密被灰黄色平贴绒毛边狭膜质内层长卵形半膜质背面近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#腺毛蒿组"/>
