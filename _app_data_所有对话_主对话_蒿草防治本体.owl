    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长外层长卵形边膜质紫色中内层长卵形或椭圆形半膜质或膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#龙蒿组"/>
    <art:中文名>康马蒿</art:中文名>
    <rdfs:label>康马蒿</rdfs:label>
  </rdf:Description>
