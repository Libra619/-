    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#陕西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶卵圆形或近圆形二回羽状全裂小裂片狭匙形倒披针形或线状倒披针形宽0_5_1_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#近球形直径3_5_4_5mm具短梗排成中等开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_xerophytica_Krasch"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根粗大木质垂直伸长根状茎粗短直径达2_4cm上部常分化出若干部分有多数营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#小灌木状"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面被灰黄色或淡灰黄色略带绢质短绒毛"/>
    <art:特殊特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根系粗大深长耐干旱抗风沙"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#具白色托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花4_10朵花冠近狭圆锥状檐部3_2裂齿外面被短柔毛两性花10_20朵孕育花冠檐部外面被短柔毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层狭卵形背面被灰黄色短柔毛中间具绿色中肋边狭膜质中层卵形背面被短柔毛边宽膜质内层半膜质背面近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
