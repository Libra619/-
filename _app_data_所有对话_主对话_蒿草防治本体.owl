    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#拉丁名"/>
    <rdfs:label>Artemisia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#茎下部与中部叶卵形或长卵形一至二回羽状深裂或第一回全裂第二回为深裂每侧裂片3_4_5枚小裂片边缘具2_3枚浅裂齿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#叶形态与分裂"/>
    <rdfs:label>茎下部与中部叶卵形或长卵形，一至二回羽状深裂或第一回全裂第二回为深裂，每侧裂片(3-)4-5枚，小裂片边缘具2-3枚浅裂齿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#总苞片3层外中层长卵形或宽卵形先端钝圆近革质绿褐色无毛边缘狭膜质内层长卵形或倒卵形边缘宽膜质">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#总苞片特征"/>
