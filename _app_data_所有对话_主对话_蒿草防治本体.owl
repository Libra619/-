  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#东北丝裂蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎中部叶卵圆形一至二回羽状全裂小裂片狭线形宽0_5_1mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#近球形直径2_3mm具短梗下垂排成狭窄圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_adamsii_Bess"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根细长或稍粗根状茎稍粗短有少数营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本或半灌木状"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#叶暗绿色常被腺点及蛛丝状柔毛后渐脱落绿色"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起半球形"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花9_12朵花冠狭圆锥状背面有腺点两性花35_45朵结实或中央数朵不结实花冠管状外面稍有腺点或无腺点"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层长椭圆形至长卵形背面微被短柔毛边缘膜质中内层略长卵圆形或宽卵形近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>东北丝裂蒿</art:中文名>
    <rdfs:label>东北丝裂蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#球形直径4_5mm具短梗与线形小苞叶排成穗状花序式总状花序在茎上组成开展且伸长的圆锥花序">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#头状花序特征"/>
