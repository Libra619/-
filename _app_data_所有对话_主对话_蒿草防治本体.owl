  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#海州蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山东省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#江苏省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#基生叶卵形或宽卵形三至四回羽状全裂小裂片狭线形宽0_5_1_5mm下部与中部叶宽卵形二至三回羽状全裂小裂片狭线形宽0_5_1_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#卵球形或卵球状倒圆锥形直径2_3_4mm具短梗或近无梗下垂排成复总状花序并在茎上组成略开展或狭长圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_fauriei_Nakai"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根单一垂直狭纺锤形根茎稍粗短直立直径0_5_1_5_2cm偶有营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#叶稍肉质初时被蛛丝状绒毛后无毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起有白色托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花2_5朵花冠狭管状外面密被腺体檐部2_3裂齿两性花8_15朵孕育花冠管状背面下部有腺点"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层与中层卵形或长卵形初时背面微被蛛丝状绒毛后近无毛具绿色中肋及膜质边缘内层长卵形半膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>海州蒿</art:中文名>
    <rdfs:label>海州蒿</rdfs:label>
  </rdf:Description>
