    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#基生叶与茎下部叶长7_8cm宽5_7_5cm二至三回羽状全裂或深裂小裂片长1_2cm宽2_4mm头状花序的总苞片先端常反卷"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序排成狭窄圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_chienshanica_Ling_et_W_Wang"/>
