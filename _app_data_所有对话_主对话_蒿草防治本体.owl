<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:art="http://www.example.org/ontology/Artemisia#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#矮滨蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#基生叶卵圆形三回羽状全裂小裂片狭线形宽0_5mm茎下部与中部叶近圆形或卵圆形一至二回羽状全裂小裂片狭线形宽0_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#椭圆状倒圆锥形直径2_3_4mm具短梗及狭线形小苞叶下垂排成总状或复总状花序并在茎上组成中等开展或狭长圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_nakai_Pamp"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根单一垂直近狭纺锤形"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#二年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#茎枝叶两面初时密被蛛丝状绢质柔毛后脱落无毛微有白霜"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花2_5朵花冠狭管状两性花8_16朵孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层与中层卵形或长卵形背面初时密被蛛丝状绵毛后稍稀疏或微有毛有绿色中肋及膜质边缘内层半膜质背面近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>矮滨蒿</art:中文名>
    <rdfs:label>矮滨蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#天敌昆虫防治">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#生物防治"/>
    <art:季节是 rdf:resource="http://www.example.org/ontology/Artemisia#全年"/>
    <art:适用于防治 rdf:resource="http://www.example.org/ontology/Artemisia#大籽蒿"/>
    <art:难度是 rdf:resource="http://www.example.org/ontology/Artemisia#复杂"/>
    <art:单位成本>400.0</art:单位成本>
    <art:持效期>365</art:持效期>
    <art:环境安全性>高</art:环境安全性>
    <art:适用苗龄>全生育期</art:适用苗龄>
    <art:防治效果>70.0</art:防治效果>
    <rdfs:label>天敌昆虫防治</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#含挥发油作香料">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#化学成分"/>
    <rdfs:label>含挥发油（作香料）</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#包含">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/ontology/Artemisia#分类单元"/>
    <rdfs:range rdf:resource="http://www.example.org/ontology/Artemisia#分类单元"/>
    <rdfs:label>包含</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#茎枝叶两面初时密被蛛丝状绢质柔毛后脱落无毛微有白霜">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#毛被与腺体"/>
    <rdfs:label>茎、枝、叶两面初时密被蛛丝状绢质柔毛，后脱落无毛，微有白霜</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#监测技术">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#致敏物质是">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <rdfs:range rdf:resource="http://www.example.org/ontology/Artemisia#致敏物质"/>
    <rdfs:label>致敏物质是</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#菊科">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#科"/>
    <art:包含 rdf:resource="http://www.example.org/ontology/Artemisia#春黄菊族"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Asteraceae"/>
    <art:中文名>菊科</art:中文名>
    <rdfs:label>菊科</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#裂叶蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#吉林省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#宁夏回族自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#陕西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶椭圆状长圆形或长卵形二至三回栉齿状羽状分裂小裂片椭圆状披针形或栉齿小裂片不再分裂或边缘具若干小锯齿"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#球形或半球形直径2_3_3_5mm下垂排成略狭窄的扫帚形圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_tanacetifolia_Linn"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根细根状茎稍粗匍地或斜向上"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面绿色微有凹点无毛或疏被短绒毛背面初时密被白色短绒毛后稍稀疏"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起半球形"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_15朵花冠狭管状背面有腺点檐部2裂齿背面常有短柔毛两性花30_40朵孕育花冠管状背面有腺点檐部背面有短柔毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3层内层近等长外层狭卵形或椭圆状卵形淡绿色背面无毛或初时微有稀疏短绒毛后渐脱落边缘狭膜质中层卵形背面无毛边缘宽膜质内层近膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>裂叶蒿</art:中文名>
    <rdfs:label>裂叶蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#奇蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#活血通经清热解毒消炎止痛消食治肠胃及妇科疾病血丝虫病"/>
    <art:包含成分 rdf:resource="http://www.example.org/ontology/Artemisia#含挥发油黄酮苷酚类氨基酸等"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶厚纸质卵形至卵状披针形不分裂边缘具细锯齿"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序卵形直径2_2_5毫米"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_anomala"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根状茎粗壮"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面被微糙毛下面被蛛丝状毛或近无毛"/>
    <art:致敏物质是 rdf:resource="http://www.example.org/ontology/Artemisia#花粉"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花4_6朵两性花6_8朵均结实"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片半膜质或膜质背面淡黄色无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#白苞蒿组"/>
    <art:中文名>奇蒿</art:中文名>
    <rdfs:label>奇蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#基生叶椭圆形或长卵形二至三回羽状全裂小裂片狭线形宽1_2mm中部叶卵形宽卵形或椭圆状卵形一至二回羽状全裂小裂片狭线形宽0_5_1_5mm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#叶形态与分裂"/>
    <rdfs:label>基生叶椭圆形或长卵形，二至三回羽状全裂，小裂片狭线形宽1-2mm；中部叶卵形、宽卵形或椭圆状卵形，一至二回羽状全裂，小裂片狭线形宽0.5-1.5mm</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#球形或半球形直径1_5_2_5_3_5mm具短梗或近无梗排成狭窄穗状花序式圆锥花序或穗状花序式总状花序">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#头状花序特征"/>
    <rdfs:label>球形或半球形，直径1.5-2.5(-3.5)mm，具短梗或近无梗，排成狭窄穗状花序式圆锥花序或穗状花序式总状花序</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#二郎山蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部叶近圆形或宽卵形一至二回羽状深裂或近全裂每侧裂片3枚中部叶宽卵形或卵形一至二回羽状深裂每侧裂片2_3枚裂片椭圆形或椭圆状披针形宽8_20mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形近球形或宽卵形直径3_4mm无梗在茎上端分枝的小枝上每3_6_8枚密集成圆球形或长圆球形的复头状花序在茎上组成开展大型圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_erlangshanensis_Ling_et_Y_R_Ling"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根明显粗木质侧根多数根状茎粗短直径5_15mm斜向上"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#叶面深绿色初时疏被短柔毛与白色腺点后脱落留有小凹点背面除脉外密被淡灰黄色或淡灰白色蛛丝状绵毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_15朵花冠狭管状檐部2裂齿两性花15_25朵孕育花冠管状檐部紫色微有柔毛或无毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长或外层略短小外中层卵形或长卵形初时微有淡黄色短柔毛后无毛中肋绿色边宽膜质内层长卵形半膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#二郎山蒿系"/>
    <art:中文名>二郎山蒿</art:中文名>
    <rdfs:label>二郎山蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#近球形直径2_3mm无柄每2_5枚成簇集生排成穗状花序在茎上组成疏松开展圆锥花序">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#头状花序特征"/>
    <rdfs:label>近球形，直径2-3mm，无柄，每2-5枚成簇集生排成穗状花序，在茎上组成疏松开展圆锥花序</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#Artemisia_sphaerocephala">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#拉丁名"/>
    <rdfs:label>Artemisia sphaerocephala</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#滇艾">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#台湾省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#浙江省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#基生叶密集成莲座状长卵形或近扇形二至三回羽状全裂小裂片狭线形或狭线状披针形宽1_5_2mm茎下部与中部叶长卵形羽状全裂裂片狭线形或狭线状披针形宽1_5_2mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#倒圆锥形直径4_5mm具短梗5_10mm下垂排成复总状花序在茎上组成中等开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_fukudo_Makino"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根明显垂直狭纺锤形根状茎细短偶有营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#二年生或多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#叶质稍厚初时被灰绿色蛛丝状柔毛后脱落"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_15朵花冠狭管状檐部1_2裂齿两性花20_30朵不孕育花冠管状花柱短先端稍叉开叉端钝"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层与中层卵形或长卵形具膜质边缘内层长卵形半膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>滇艾</art:中文名>
    <rdfs:label>滇艾</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#基生叶与茎下部叶长卵形或长圆形一至二回羽状分裂第一回全裂每侧裂片4_5枚每裂片再羽状深裂或半裂小裂片或裂齿椭圆形中部叶长圆形或倒卵状长圆形羽状深裂或几全裂每侧裂片4_5枚裂片椭圆形或长圆形边缘有1_2枚小裂齿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#叶形态与分裂"/>
    <rdfs:label>基生叶与茎下部叶长卵形或长圆形，一至二回羽状分裂，第一回全裂，每侧裂片4-5枚，每裂片再羽状深裂或半裂，小裂片或裂齿椭圆形；中部叶长圆形或倒卵状长圆形，羽状深裂或几全裂，每侧裂片4-5枚，裂片椭圆形或长圆形，边缘有1-2枚小裂齿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#茎枝初时有短绒毛后渐脱落无毛叶初时被短柔毛后渐稀疏近无毛">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#毛被与腺体"/>
    <rdfs:label>茎、枝初时有短绒毛后渐脱落无毛；叶初时被短柔毛后渐稀疏近无毛</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#茎下部与中部叶椭圆形或长圆形一至二回羽状深裂或几全裂每侧裂片4_5枚小裂片线形或线状披针形宽2_5_3_5mm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#叶形态与分裂"/>
    <rdfs:label>茎下部与中部叶椭圆形或长圆形，一至二回羽状深裂或几全裂，每侧裂片4-5枚，小裂片线形或线状披针形宽2.5-3.5mm</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#上面疏被粘质腺毛或近无毛下面被蛛丝状绒毛及疏腺毛">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#毛被与腺体"/>
    <rdfs:label>上面疏被粘质腺毛或近无毛；下面被蛛丝状绒毛及疏腺毛</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#主根稍木质化根状茎稍粗具多数细短多年生营养枝其上密生营养叶">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#根状茎特征"/>
    <rdfs:label>主根稍木质化；根状茎稍粗，具多数细短多年生营养枝，其上密生营养叶</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#Artemisia_austriaca_Jacq">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#拉丁名"/>
    <rdfs:label>Artemisia austriaca Jacq.</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#五月艾">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#上海市"/>
