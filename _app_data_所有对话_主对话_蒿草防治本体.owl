  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#菴">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#吉林省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山东省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#止血消炎驱风活络"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶倒卵形卵状椭圆形或倒卵状匙形不分裂宽1_5_4cm中部以上边缘具数枚疏锯齿或浅裂齿"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#近球形直径3_3_5mm具细梗1_5_2mm排成总状或复总状花序在茎上组成狭窄或疏而稍开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_keiskeana_Miq"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根略明显侧根细而多根状茎短直径约3mm有少数营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面绿色初时微有短柔毛后脱落无毛背面淡绿色有时具腺点多少被稀疏短柔毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#小半球形"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花6_10朵花冠狭圆锥状檐部2裂齿背面具小腺点两性花13_18朵花冠管状部分为狭管状背面具小腺点偶有短柔毛花柱略短于花冠或近等长顶端2叉叉端钝尖无睫毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层背面绿色无毛外层小卵形顶端钝中内层椭圆形或长卵形背面绿色或黄褐色边缘宽膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#菴_系"/>
    <art:中文名>菴䕅</art:中文名>
    <rdfs:label>菴䕅</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#营养枝叶与茎下部及中部叶宽卵形二回羽状全裂每侧裂片2_3_4枚小裂片狭线形宽1_5_2_5mm先端具硬尖头">
