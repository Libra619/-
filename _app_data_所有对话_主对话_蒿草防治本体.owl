  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#银蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:包含成分 rdf:resource="http://www.example.org/ontology/Artemisia#含挥发油作香料"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶长卵形或椭圆状卵形二至三回羽状全裂小裂片狭线形宽0_5_1mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#卵球形或卵钟形直径1_2mm无梗排成密穗状花序在茎上组成开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_austriaca_Jacq"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根木质斜向下根状茎细或稍粗匍地或斜向上有营养枝并密生营养叶"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本有时成半灌木状"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#茎枝叶两面及总苞片背面密被银白色或淡灰黄色略带绢质绒毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#小凸起"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花3_7朵花冠狭管状或狭圆锥状檐部2_3裂齿两性花7_8朵不孕育花冠管状檐部背面有短柔毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层短小披针形或线状披针形背面密被银白色或灰白色绢质绒毛边狭膜质中内层卵形长卵形或长卵状匙形半膜质至膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>银蒿</art:中文名>
    <rdfs:label>银蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#雌花15_20朵花冠狭管状檐部2裂齿两性花60_80朵孕育花冠管状外面有腺点">
