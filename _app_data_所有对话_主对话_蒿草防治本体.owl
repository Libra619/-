  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#腺毛蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶长圆形或长卵形二回羽状分裂第一回全裂每侧裂片4_6_8枚再次羽状深裂或全裂小裂片椭圆形或椭圆状披针形长0_5_1_5cm宽3_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形或宽卵形直径4_6mm具短梗下垂单生或2_3枚密集着生排成总状花序穗状花序或复总状花序在茎上组成开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_viscida_Mattf_Pamp"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根稍明显侧根少数根状茎稍粗直径5_13mm斜向上"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面深绿色被明显短腺毛背面灰白色除叶脉外密被平贴蛛丝状绒毛背面叶脉凸起白色被稀疏腺毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花9_15朵花冠狭管状檐部2裂齿两性花18_33朵孕育花冠管状檐部紫红色"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长外中层卵形或长卵形背面微有腺毛初时密被锈色绒毛后渐脱落边膜质紫褐色内层长卵形半膜质近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#腺毛蒿组"/>
    <art:中文名>腺毛蒿</art:中文名>
    <rdfs:label>腺毛蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#密毛奇蒿">
