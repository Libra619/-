  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#片马蒿变种">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎中部叶二回羽状分裂叶的上半部裂片为深裂或浅裂下半部裂片为全裂每侧裂片3_4_5枚再次羽状浅裂每侧具3_4枚小裂片每裂片及小裂片边缘疏生细锯齿叶基部常有假托叶"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序排成穗状花序式总状花序在茎上组成开展圆锥花序花冠檐部紫色无毛"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_zay_ensis_var_pienmaensis_Ling_et_Y_R_Ling"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:中文名>片马蒿(变种)</art:中文名>
    <rdfs:label>片马蒿(变种)</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#龙蒿组">
