  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#甘青小蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶长圆形或椭圆形羽状全裂每侧裂片2_3枚裂片狭线形宽1_2mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#宽卵形或半球形直径2_5_3mm具短梗或近无梗排成穗状花序式总状花序或复总状花序在茎上排成疏松略开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_przewalskii_Krasch"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根单一纤细侧根少"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#一年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#叶初时有蛛丝状绵毛后稀疏或渐无毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_12朵花冠狭管状或略呈狭圆锥状檐部2裂齿两性花10_18朵不孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层略狭小外中层披针形或卵形背面暗褐色或绿褐色初时密被绵毛后稀疏边狭膜质内层倒卵形半膜质顶端有撕裂齿"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>甘青小蒿</art:中文名>
    <rdfs:label>甘青小蒿</rdfs:label>
  </rdf:Description>
