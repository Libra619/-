  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#台湾狭叶艾">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#台湾省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#基生叶茎下部及中部叶长圆状倒卵形或椭圆状倒卵形二回羽状全裂每侧裂片3_4_5枚小裂片披针形或线状披针形宽2_3_4mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#宽卵形或近半球形直径3_5_4mm具短梗及小苞叶梗长2_2_5mm排成短总状花序在茎上组成狭窄或略开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_somai_Hayata"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根细长侧根略少根状茎短斜向上直径4_6mm有营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#表面初时被灰白色绢质柔毛以后稀疏近无毛背面密被白色绵毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#圆锥形"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_15朵花冠狭管状檐部2_3裂齿两性花18_25朵孕育花冠管状或高脚杯状檐部外卷外面具腺点"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层略小卵形背面被白色短柔毛先端尖边狭膜质中层椭圆形先端圆常有撕裂背面被白色短柔毛边宽膜质内层倒卵状椭圆形半膜质背面毛少或近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#南方大头蒿系"/>
    <art:中文名>台湾狭叶艾</art:中文名>
    <rdfs:label>台湾狭叶艾</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#净初级生产力">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#生态系统功能指标"/>
    <art:严重阈值>100.0</art:严重阈值>
