    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶椭圆形或长圆形一至二回羽状深裂或几全裂每侧裂片4_5枚小裂片线形或线状披针形宽2_5_3_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#椭圆形或长卵钟形直径2_3mm无梗排成穗状花序在茎上组成开展或略开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_fulgens_Pamp"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根明显侧根多根状茎稍粗"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面无毛背面初时疏被苍白色平贴短柔毛后渐脱落"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花6_8朵花冠狭管状或近狭圆锥状檐部2裂齿两性花10_20朵孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层略短小外中层卵形或长卵形背面初时疏被蛛丝状薄毛后脱落无毛或近无毛中肋绿色边膜质内层长卵形或长圆形半膜质顶端有啮蚀状裂齿"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#亮蒿系"/>
    <art:中文名>亮蒿</art:中文名>
    <rdfs:label>亮蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#甘青蒿">
