  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#阴地蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#云南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#吉林省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#安徽省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山东省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#江苏省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#江西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#浙江省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#湖北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#湖南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#贵州省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#陕西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶卵形或长卵形一至二回羽状深裂每侧裂片2_3枚裂片椭圆形或长卵形再次3_5深裂或浅裂或不分裂小裂片或裂片长椭圆形或椭圆状披针形边缘常有疏锯齿或无锯齿"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#近球形或宽卵形直径1_5_2_2_5cm疑为mm原文为cm但应为mm具短梗及细小线形小苞叶下垂排成穗状花序式总状花序在茎上组成疏松开展具多级分枝圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_sylvatica_Maxim"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根稍明显侧根细根状茎稍粗短斜向上直径3_6mm"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面绿色初时叶面微有短柔毛并疏生少量白色腺点后脱落无毛无腺点背面被灰白色蛛丝状薄绒毛或近无毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花4_7朵花冠狭管状或狭圆锥状两性花8_14朵孕育花冠管状外面有腺点"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层略小外中层卵形或长卵形背面初时微被蛛丝状薄毛后脱落近无毛中肋绿色边膜质内层长卵形或长圆状倒卵形半膜质背面近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#阴地蒿系"/>
    <art:中文名>阴地蒿</art:中文名>
    <rdfs:label>阴地蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#千山蒿">
