    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花5_7朵花冠狭管状两性花不孕育"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#龙蒿组"/>
    <art:中文名>白莎蒿</art:中文名>
    <rdfs:label>白莎蒿</rdfs:label>
  </rdf:Description>
