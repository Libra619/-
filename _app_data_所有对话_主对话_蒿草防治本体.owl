  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#样方调查法">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#地面监测"/>
    <art:监测对象 rdf:resource="http://www.example.org/ontology/Artemisia#冷蒿"/>
    <art:监测对象 rdf:resource="http://www.example.org/ontology/Artemisia#大籽蒿"/>
    <art:监测对象 rdf:resource="http://www.example.org/ontology/Artemisia#艾"/>
    <art:监测对象 rdf:resource="http://www.example.org/ontology/Artemisia#黄花蒿"/>
