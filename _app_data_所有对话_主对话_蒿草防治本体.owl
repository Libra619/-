    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#头状花序特征"/>
    <rdfs:label>卵球形或卵状钟形，直径2.5-3.5mm，具短梗或近无梗略下倾，排成短总状花序或穗状花序，在茎上组成略狭窄圆锥花序</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长外层卵状披针形或长卵形背面被灰白色短柔毛中肋明显绿色边缘狭膜质中内层卵形或宽卵形背面微有短柔毛边缘宽膜质内层膜质背面无毛">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#总苞片特征"/>
    <rdfs:label>总苞片3-4层内层近等长，外层卵状披针形或长卵形背面被灰白色短柔毛中肋明显绿色边缘狭膜质，中内层卵形或宽卵形背面微有短柔毛边缘宽膜质，内层膜质背面无毛</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#空间分辨率">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.example.org/ontology/Artemisia#监测技术"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>如：0.5米、10米</rdfs:comment>
    <rdfs:label>空间分辨率</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#雌花4_8朵花冠狭圆锥状檐部3_2裂齿两性花8_14朵孕育花冠管状檐部紫色">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#花结构与育性"/>
    <rdfs:label>雌花4-8朵，花冠狭圆锥状，檐部3-2裂齿；两性花8-14朵孕育，花冠管状檐部紫色</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#雌花8_12朵花冠狭圆锥状或狭管状冠檐2_3裂齿两性花30_40朵孕育花冠管状外面被腺点">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#花结构与育性"/>
    <rdfs:label>雌花8-12朵，花冠狭圆锥状或狭管状，冠檐2-3裂齿；两性花30-40朵孕育，花冠管状外面被腺点</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#卵球形直径0_5_1_1_5mm具短梗排成多分枝开展圆锥花序">
