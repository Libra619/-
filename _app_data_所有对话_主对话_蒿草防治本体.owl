  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#耐旱性强抗风固沙性能好果壁胶质物遇水膨胀可胶结沙粒">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#特殊适应"/>
