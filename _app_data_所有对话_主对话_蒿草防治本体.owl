    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#福建省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#叶面初时疏被短糙毛叶背密被灰白色或灰黄色宿存绵毛"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_anomala_var_tomentella_Hand_Mazz"/>
