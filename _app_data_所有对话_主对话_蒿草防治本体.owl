    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#宽卵形或卵钟形直径3_3_5mm无梗排成疏松穗状花序在茎上部组成中等开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_viscidissima_Ling_et_Y_R_Ling"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根明显侧根少数根状茎稍粗直径4_5mm斜向上"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生半灌木状草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面深绿色密被明显腺毛背面除叶脉外被灰白色短柔毛脉上有腺毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花5_10朵花冠狭管状檐部2_3浅裂齿两性花10_15朵孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层小狭卵形背面被棕褐色短柔毛中内层长卵形背面毛少边宽膜质或全半膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#腺毛蒿组"/>
    <art:中文名>密腺毛蒿</art:中文名>
    <rdfs:label>密腺毛蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#尖栉齿叶蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶椭圆形或长圆形一至二回栉齿状羽状分裂栉齿短披针形或短线状披针形宽1_2mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形直径4_6mm下部头状花序具长梗上部具短梗或近无梗排成疏松总状花序或总状花序式狭圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_medioxima_Krasch_ex_Poljak"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根细根状茎斜上展略长或短而直立具少数营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面无毛常有小凹点背面淡绿色疏被灰白色叉状短柔毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起半球形"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_10朵花冠狭管状或狭圆锥状檐部2裂齿两性花20_40朵孕育花冠管状檐部外面常有短柔毛或无毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长外层狭椭圆形或长圆状披针形外面被短柔毛边缘狭膜质中内层略大卵形无毛或近无毛边缘宽膜质或全膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>尖栉齿叶蒿</art:中文名>
    <rdfs:label>尖栉齿叶蒿</rdfs:label>
  </rdf:Description>
