  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#白莲蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#清热解毒祛风利湿可作_茵陈_代用品止血"/>
    <art:包含成分 rdf:resource="http://www.example.org/ontology/Artemisia#含挥发油倍半萜内酯"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶二至三回栉齿状羽状分裂小裂片栉齿状披针形中轴有栉齿"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序近球形直径2_3_5毫米"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_sacrorum"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根状茎粗壮常有营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本或亚灌木"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#幼时被灰白色短柔毛后脱落"/>
    <art:致敏物质是 rdf:resource="http://www.example.org/ontology/Artemisia#花粉"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#圆锥状有托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_12朵两性花20_40朵均结实"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#外层总苞片披针形背面初时密被短柔毛后无毛有绿色中肋"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>白莲蒿</art:中文名>
    <rdfs:label>白莲蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#伊朗蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#民间作消炎止血健胃用药"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶近圆形或卵形二至三回羽状全裂小裂片狭而短近成栉齿状线状披针形或狭而短线形宽0_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形直径3_4_5mm有短梗及小苞叶下垂或斜生排成穗状花序式总状花序或复总状花序在茎上组成略开展或狭长圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_persica_Boiss"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根垂直根状茎稍粗大木质有短木质营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面被稀疏蛛丝状短柔毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起半球形具白色托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_15朵花冠狭圆锥状或近狭瓶状檐部2_3裂齿两性花35_50朵孕育花冠管状檐部紫色初时外面被疏短柔毛后脱落"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层与中层卵形或长卵形背面密生白色蛛丝状短柔毛边膜质内层长卵形或宽卵形背面毛少或近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>伊朗蒿</art:中文名>
    <rdfs:label>伊朗蒿</rdfs:label>
  </rdf:Description>
