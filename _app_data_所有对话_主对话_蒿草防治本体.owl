    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶长卵形或椭圆形二回羽状分裂第一回全裂或近全裂每侧裂片4_5_6枚小裂片或裂齿椭圆形或长卵形中央一枚小裂片最长0_5_1_2cm宽2_4mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#长卵形或长圆形直径1_5_2mm无梗或近无梗排成穗状花序或复穗状花序在茎上组成开展具多级分枝圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_abaensis_Y_R_Ling_et_S_Y_Zhao"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根细根状茎细或略粗"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面微被蛛丝状柔毛偶具稀疏白色腺点背面密被灰白色蛛丝状绵毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花2_5朵花冠狭管状檐部2裂齿或无裂齿紫色两性花4_8朵孕育花冠管状檐部紫色"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层小狭卵形背面疏被蛛丝状短柔毛中层略长卵形背面微被蛛丝状柔毛外中层均具绿色中肋内层半膜质卵形背面近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#小球花蒿系"/>
    <art:中文名>阿坝蒿</art:中文名>
    <rdfs:label>阿坝蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#基生叶与茎下部叶长7_8cm宽5_7_5cm二至三回羽状全裂或深裂小裂片长1_2cm宽2_4mm头状花序的总苞片先端常反卷">
