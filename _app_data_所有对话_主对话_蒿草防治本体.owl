    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶二回羽状全裂小裂片丝线形宽0_3_0_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#卵球形直径0_5_1_1_5mm具短梗排成多分枝开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_pewzowii_C_Winkl"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#一二年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面被短柔毛毛宿存"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#龙蒿组"/>
    <art:中文名>纤梗蒿</art:中文名>
