    <rdfs:label>种子自然传播距离</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#根木质粗大垂直根状茎粗黑色具多数木质短营养枝枝上密生营养叶">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#根状茎特征"/>
    <rdfs:label>根木质粗大垂直；根状茎粗黑色，具多数木质短营养枝，枝上密生营养叶</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#雌花7_9朵花冠狭圆锥形檐部2裂齿两性花14_22朵不孕育花冠管状">
