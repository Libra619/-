  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#茎下部与中部叶椭圆形或倒卵形一至二回或二回羽状全裂或深裂每侧裂片1_2枚裂片线形或倒披针状线形宽1_2mm先端圆钝不再分裂或每侧间有1至数枚小圆齿或小深裂片">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#叶形态与分裂"/>
    <rdfs:label>茎下部与中部叶椭圆形或倒卵形，一至二回或二回羽状全裂或深裂，每侧裂片1-2枚，裂片线形或倒披针状线形宽1-2mm，先端圆钝不再分裂或每侧间有1至数枚小圆齿或小深裂片</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#基生叶卵形或宽卵形莲座状二回羽状全裂茎下部与中部叶长圆形或椭圆形一至二回羽状全裂每侧具3_4枚裂片小裂片线形或线状披针形宽0_5_1_2mm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#叶形态与分裂"/>
    <rdfs:label>基生叶卵形或宽卵形莲座状，二回羽状全裂；茎下部与中部叶长圆形或椭圆形，一至二回羽状全裂，每侧具3(-4)枚裂片，小裂片线形或线状披针形宽0.5-1(-2)mm</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#主根单一狭纺锤形侧根多数">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#根状茎特征"/>
    <rdfs:label>主根单一狭纺锤形，侧根多数</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#雌花5_7朵花冠狭圆锥状檐部2_3裂齿两性花15_22朵孕育花冠管状檐部稍被短柔毛">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#花结构与育性"/>
    <rdfs:label>雌花5-7朵，花冠狭圆锥状，檐部2-3裂齿；两性花15-22朵孕育，花冠管状檐部稍被短柔毛</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#银叶蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#宁夏回族自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶与营养枝叶倒卵状椭圆形或椭圆形一至二回羽状全裂小裂片椭圆形或椭圆状倒披针形宽0_5_1_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形或近卵钟形直径4_7mm有短梗及小苞叶下垂排成总状花序并在茎上组成中等开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_argyrophylla_Ledeb"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根稍粗木质根状茎短具多数营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本或近半灌木状"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#茎枝叶两面及总苞片背面密被银白色稍带绢质短柔毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花5_10朵花冠狭圆锥状檐部2_3裂齿两性花20_40朵孕育花冠檐部紫色被白色短柔毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层与中层卵形或长卵形边狭膜质内层边宽膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>银叶蒿</art:中文名>
    <rdfs:label>银叶蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#川西腺毛蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶长圆形或椭圆形二回羽状全裂每侧裂片4_5枚顶端小裂片最长线形或线状披针形长1_5_2_5cm宽1_5_2_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#长卵形或长卵状钟形直径1_5_2_5mm无梗下垂排成穗状或复穗状花序在茎上组成开展大型具多级分枝圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_occidentali_sichuanensis_Y_R_Ling_et_S_Y_Zhao"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根状茎细"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面及叶背脉上被短腺毛背面除脉外密被灰白色蛛丝状柔毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花3_5朵花冠狭管状檐部2裂齿两性花4_8朵孕育花冠管状基部有小腺点檐部紫色"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层小披针形背面近无毛或微微蛛丝状柔毛具绿色中肋中内层卵形或长卵形背面疏被蛛丝状柔毛或近无毛具绿色中肋"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#腺毛蒿组"/>
    <art:中文名>川西腺毛蒿</art:中文名>
    <rdfs:label>川西腺毛蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#经济损失">
