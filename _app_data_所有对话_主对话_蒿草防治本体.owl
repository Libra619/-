  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#球花蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#基生叶莲座状椭圆状卵形或长卵形一至二回羽状深裂每侧裂片3_4_6枚小裂片披针形或椭圆状披针形宽3_5mm中部叶长圆形或长圆状椭圆形羽状全裂每侧裂片3_4枚裂片披针形线状披针形或倒披针形宽2_3mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形直径6_10mm单生于苞片叶腋内具梗3_10mm下垂在茎上组成细长总状花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_smithii_Mattf"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根明显近木质侧根少数根状茎稍粗直径3_6mm稍木质偶有营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面被灰白色蛛丝状绢质柔毛背面尤密"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起半球形"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_16朵花冠狭管状檐部2_3裂齿紫色常有短柔毛背面有腺点两性花50_60朵孕育花冠管状背面有腺点檐部紫色具短柔毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层略短小卵形背面密被淡黄色柔毛边缘狭膜质中层长卵形背面密被淡黄色柔毛边缘宽膜质内层长卵形或长圆形背面毛略少半膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#球花蒿系"/>
    <art:中文名>球花蒿</art:中文名>
    <rdfs:label>球花蒿</rdfs:label>
  </rdf:Description>
