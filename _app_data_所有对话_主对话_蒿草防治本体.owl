  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#雌花7_10朵花冠狭管状或狭圆锥状檐部3_4裂齿外面被短柔毛两性花30_80朵孕育花冠管状檐部外面有短柔毛">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#花结构与育性"/>
    <rdfs:label>雌花7-10朵，花冠狭管状或狭圆锥状，檐部3(-4)裂齿外面被短柔毛；两性花30-80朵孕育，花冠管状檐部外面有短柔毛</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#乌丹蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:包含成分 rdf:resource="http://www.example.org/ontology/Artemisia#果壁有细纵纹并含胶质物"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#营养枝叶与茎下部及中部叶宽卵形二回羽状全裂每侧裂片2_3_4枚小裂片狭线形宽1_5_2_5mm先端具硬尖头"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#球形或近球形直径4_5mm具短梗及线形小苞叶下垂排成狭长总状花序在茎上组成狭窄伸长或略开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_wudanica_Liou_et_W_Wang"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根粗壮深长垂直灰黑色根状茎粗大木质直径达2cm具多数营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#小灌木"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#叶质厚无毛"/>
    <art:特殊特征是 rdf:resource="http://www.example.org/ontology/Artemisia#耐旱性强抗风固沙性能好果壁胶质物遇水膨胀可胶结沙粒"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#圆锥形凸起"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花7_9朵花冠狭圆锥形檐部2裂齿两性花14_22朵不孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3层外中层长卵形或宽卵形先端钝圆近革质绿褐色无毛边缘狭膜质内层长卵形或倒卵形边缘宽膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#圆头蒿系"/>
    <art:中文名>乌丹蒿</art:中文名>
    <rdfs:label>乌丹蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#雌花1层15_25朵花冠狭圆锥状或狭管状檐部2裂齿两性花4_6层30_70_90朵孕育">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#花结构与育性"/>
    <rdfs:label>雌花1层(15-25朵)，花冠狭圆锥状或狭管状，檐部2裂齿；两性花4-6层(30-70(-90)朵)孕育</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#Artemisia_sacrorum_var_incana_Bess_Y_R_Ling">
