  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#绢毛蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#宁夏回族自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶与营养枝叶椭圆形或卵形二回羽状全裂小裂片线形或线状披针形宽1_5_2mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形直径4_5_6_9mm有短梗下垂或斜展排成穗状花序式总状花序或狭窄总状花序式圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_sericea_Web_ex_Stechm"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根木质根状茎稍粗木质具少数营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本或半灌木状"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面密被淡黄色或灰黄色绢质短绒毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起半球形具白色托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_14朵花冠狭圆锥状或狭管状檐部2_3裂齿两性花40_80朵孕育"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层与中层卵形或椭圆形背面密被白色柔毛边缘褐色狭膜质内层椭圆形膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>绢毛蒿</art:中文名>
    <rdfs:label>绢毛蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#粘毛蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
