  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#商南蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#云南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#陕西省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶卵形或长卵形二至三回羽状分裂末回为深裂齿或宽栉齿宽3mm以上"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形或近球形直径5_7mm具短梗下垂排成开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_shangnanensis_Ling_et_Y_R_Ling"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根单一垂直狭纺锤状"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#一二年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#初时两面被淡黄色或灰黄色短柔毛后渐稀疏"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花1_2层15_20朵花冠狭管状或狭圆锥状檐部2_3裂齿两性花80_150朵中央少数花不孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长外层长卵形背面有绿色中肋疏被灰黄色短柔毛边宽膜质中层卵形背面近无毛边宽膜质内层长椭圆形半膜质或膜质无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>商南蒿</art:中文名>
    <rdfs:label>商南蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#歧茎蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#吉林省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山东省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#陕西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#止血消炎通经民间作艾代用品"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶卵形或宽卵形一至二回羽状分裂第一回深裂每侧裂片2_3枚裂片椭圆形或长圆形每裂片再2_3_4深裂或浅裂或边缘为数枚粗锯齿裂片先端钝或渐尖并有短尖头"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#椭圆形或长卵形直径2_5_3_5mm具短梗或近无梗排成稀疏开展或中等开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_igniaria_Maxim"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根稍明显侧根多根状茎稍粗直径4_6mm具横卧地下茎常有营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面初时被灰白色短绒毛后渐脱落无毛绿色背面密被灰白色绒毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#小凸起"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花5_8朵花冠狭管状檐部1_2裂齿两性花7_14朵孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层小椭圆形背面微被灰白色蛛丝状绵毛中层略大卵形初时背面微被蛛丝状毛后渐稀疏具绿色中肋边缘宽膜质内层倒卵形或长椭圆形半膜质背面近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#歧茎蒿系"/>
    <art:中文名>歧茎蒿</art:中文名>
    <rdfs:label>歧茎蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#亮蒿">
