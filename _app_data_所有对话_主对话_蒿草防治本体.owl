  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#锈苞蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#云南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#湖北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶宽卵形或长圆形二至三回羽状全裂每侧具4_5枚裂片小裂片披针形或线状披针形宽1_5_3mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形或近卵球形直径3_4_5mm无梗略下垂单生或2_3枚密集着生成穗状花序在茎上组成狭长或略开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_imponens_Pamp"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根细垂直侧根多根状茎细或略粗短常有营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面疏被平贴绢质柔毛并有白色腺点背面密被灰白色绵毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_10朵花冠狭圆锥状檐部2裂齿两性花10_30朵孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长或内层略长外中层狭卵形或椭圆形背面密被锈色绒毛边缘膜质内层长卵形或长圆形半膜质背面疏被锈色绒毛或近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#锈苞蒿系"/>
    <art:中文名>锈苞蒿</art:中文名>
    <rdfs:label>锈苞蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#雌花6_10朵花冠狭圆锥状檐部2裂齿背面具小腺点两性花13_18朵花冠管状部分为狭管状背面具小腺点偶有短柔毛花柱略短于花冠或近等长顶端2叉叉端钝尖无睫毛">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#花结构与育性"/>
    <rdfs:label>雌花6-10朵，花冠狭圆锥状，檐部2裂齿背面具小腺点；两性花13-18朵，花冠管状部分为狭管状背面具小腺点偶有短柔毛，花柱略短于花冠或近等长顶端2叉叉端钝尖无睫毛</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#藏沙蒿">
