    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶椭圆状长圆形或长卵形一至二回羽状深裂裂片栉齿状裂齿长3_5_13mm宽1_2_3mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#近球形或半球形直径3_4mm有短梗下垂排成狭窄圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_latifolia_Ledeb"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根单一或数枚根状茎稍长或短直径3_4mm斜升常有黑色老叶柄残基"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面具密小凹点上面无毛背面淡绿色无毛或初时疏被短柔毛后脱落无毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花5_9朵花冠狭管状外面有腺点檐部2_3裂齿两性花18_25朵孕育花冠管状外面有腺点"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长外层卵形背面无毛或近无毛黄褐色边缘宽膜质褐色常有撕裂中层椭圆形或长圆形边缘宽膜质内层膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>宽叶蒿</art:中文名>
    <rdfs:label>宽叶蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#上面暗绿色初时被灰白色短柔毛后脱落无毛或近无毛背面除叶脉外密被灰白色密绒毛">
