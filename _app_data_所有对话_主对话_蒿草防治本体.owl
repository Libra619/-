    <rdfs:label>总苞片3-4层，外层小披针形背面近无毛或微微蛛丝状柔毛具绿色中肋，中内层卵形或长卵形背面疏被蛛丝状柔毛或近无毛具绿色中肋</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#碱蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#宁夏回族自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#河北省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#陕西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#民间采基生叶作中药茵陈代用品"/>
    <art:包含成分 rdf:resource="http://www.example.org/ontology/Artemisia#含挥发油主要成分为醛类物质还含少量生物碱"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#基生叶椭圆形或长卵形二至三回羽状全裂小裂片狭线形宽1_2mm中部叶卵形宽卵形或椭圆状卵形一至二回羽状全裂小裂片狭线形宽0_5_1_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形或宽卵形直径2_3_4mm具短梗下垂或斜生排成穗状花序式总状花序并在茎上组成疏散开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_anethifolia_Web_ex_Stechm"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根单一垂直狭纺锤形"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#一二年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#茎枝初时有短绒毛后渐脱落无毛叶初时被短柔毛后渐稀疏近无毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起半球形具白色托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花3_6朵花冠狭管状两性花18_28朵孕育花冠管状檐部黄色或红色"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层与中层椭圆形或披针形背面微有白色短柔毛或近无毛有绿色中肋边缘膜质内层卵形近膜质背面无毛"/>
    <art:造成危害 rdf:resource="http://www.example.org/ontology/Artemisia#土壤退化"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>碱蒿</art:中文名>
    <rdfs:label>碱蒿</rdfs:label>
  </rdf:Description>
