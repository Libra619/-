  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#中部叶卵形或长卵形一至二回羽状深裂每侧裂片2_3枚裂片椭圆形或长卵形再次3_5深裂或浅裂或不分裂小裂片或裂片长椭圆形或椭圆状披针形边缘常有疏锯齿或无锯齿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#叶形态与分裂"/>
    <rdfs:label>中部叶卵形或长卵形，一至二回羽状深裂，每侧裂片2-3枚，裂片椭圆形或长卵形，再次3-5深裂或浅裂或不分裂，小裂片或裂片长椭圆形或椭圆状披针形，边缘常有疏锯齿或无锯齿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#主根稍粗大侧根多枚根状茎稍粗直径3_8mm半木质">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#根状茎特征"/>
    <rdfs:label>主根稍粗大侧根多枚；根状茎稍粗直径3-8mm半木质</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#上面初时被蛛丝状柔毛后近无毛下面密被蛛丝状绒毛">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#毛被与腺体"/>
    <rdfs:label>上面初时被蛛丝状柔毛后近无毛；下面密被蛛丝状绒毛</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#亚洲大花蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#下部与中部叶卵形或长圆形二回羽状分裂第一回全裂第二回深裂小裂片细短线形或短披针状线形宽0_5_1mm有时先端成镰刀状或钩状弯曲"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#近球形或半球形直径4_7mm近无梗或具短梗排成短穗状花序式总状花序在茎上组成狭窄或中等开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_macrantha_Ledeb"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根木质根状茎短直立或斜生木质有短的营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面无毛或微有短柔毛背面淡绿色被细而密短柔毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_20朵花冠狭圆锥状外面有腺点两性花30_38朵孕育花冠狭杯状或管状外面有腺点檐部外面有短柔毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内外层近等长外层椭圆状披针形革质外面被灰白色短柔毛边缘狭膜质褐色中内层卵圆形边缘宽膜质褐色或全膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>亚洲大花蒿</art:中文名>
    <rdfs:label>亚洲大花蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#白山蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#吉林省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部中部及营养枝叶匙形长椭圆状倒披针形或披针形宽0_3_1cm不分裂或先端3_5浅裂"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形或近球形直径4_6mm有短梗下垂或斜展在苞片叶腋内单生或2_5枚排成短总状式花序在茎上组成总状花序式狭圆锥花序或总状花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_lagocephala_Fisch_ex_Bess_DC"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根木质根状茎木质粗黑褐色具多数短木质营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#叶面暗绿色微有白毛或近无毛背面密被灰白色平贴短柔毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起半球形具托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花7_10朵花冠狭管状或狭圆锥状檐部3_4裂齿外面被短柔毛两性花30_80朵孕育花冠管状檐部外面有短柔毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层卵形背面密被灰褐色柔毛中内层椭圆形或椭圆状披针形背面毛少边缘膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>白山蒿</art:中文名>
    <rdfs:label>白山蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#纤梗蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
