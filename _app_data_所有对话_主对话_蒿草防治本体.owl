  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#总苞片3_4层外层略短小外中层卵形或长卵形背面初时疏被蛛丝状薄毛后脱落无毛或近无毛中肋绿色边膜质内层长卵形或长圆形半膜质顶端有啮蚀状裂齿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
