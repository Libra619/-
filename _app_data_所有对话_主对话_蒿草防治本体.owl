  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#大籽蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#消炎清热止血治高原紫外线灼伤"/>
    <art:包含成分 rdf:resource="http://www.example.org/ontology/Artemisia#含挥发油内酯类及薁类物质"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶二至三回羽状全裂小裂片线形或线状披针形"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序半球形直径4_6毫米"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_sieversiana"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根单一狭纺锤形"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#一二年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面被灰白色微柔毛"/>
    <art:特殊特征是 rdf:resource="http://www.example.org/ontology/Artemisia#适应性强在不同水湿条件下形态变异大"/>
    <art:致敏物质是 rdf:resource="http://www.example.org/ontology/Artemisia#花粉"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起半球形有白色托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花20_30朵两性花80_120朵均结实"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片背面被灰白色微柔毛或近无毛"/>
    <art:造成危害 rdf:resource="http://www.example.org/ontology/Artemisia#过敏性鼻炎"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>大籽蒿</art:中文名>
    <rdfs:label>大籽蒿</rdfs:label>
  </rdf:Description>
