    <art:时间分辨率>实时/每小时</art:时间分辨率>
    <art:监测精度>85.0</art:监测精度>
    <art:监测范围>0.5</art:监测范围>
    <art:空间分辨率>10m</art:空间分辨率>
    <rdfs:label>物联网传感监测</rdfs:label>
