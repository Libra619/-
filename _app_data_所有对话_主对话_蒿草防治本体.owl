    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#组"/>
    <art:包含 rdf:resource="http://www.example.org/ontology/Artemisia#圆头蒿系"/>
    <art:包含 rdf:resource="http://www.example.org/ontology/Artemisia#旱蒿系"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Sect_Dracunculus"/>
    <art:中文名>龙蒿组</art:中文名>
    <rdfs:label>龙蒿组</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#主根稍肥厚长狭纺锤形侧根细少根状茎稍肥大直径0_5_1_5cm黑色常有多枝基生叶叶柄残基">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#根状茎特征"/>
    <rdfs:label>主根稍肥厚长狭纺锤形侧根细少；根状茎稍肥大直径0.5-1.5cm黑色，常有多枝基生叶叶柄残基</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#上面无毛或微有短柔毛背面淡绿色被细而密短柔毛">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#毛被与腺体"/>
    <rdfs:label>上面无毛或微有短柔毛，背面淡绿色被细而密短柔毛</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#黄金蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#吉林省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶三角状卵形或三角状长卵形二至三回羽状全裂小裂片狭线状披针形或丝线形宽0_5_1mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#近球形直径2_3mm无柄每2_5枚成簇集生排成穗状花序在茎上组成疏松开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_aurata_Komar"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根单一垂直细长"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#一年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#茎枝叶及总苞片背面无毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_14朵花冠狭管状或狭圆锥状檐部2裂齿两性花14_25朵不孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3层内层近等长外层与中层宽卵形或长圆形背面中肋绿色稍凸起边缘膜质内层半膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>黄金蒿</art:中文名>
    <rdfs:label>黄金蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#香叶蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部与中部叶近半圆形或肾形二回三出全裂或二回近掌状羽状全裂小裂片长椭圆状倒披针形或椭圆状披针形宽1_1_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形或近球形直径3_4_4_5mm具短梗下垂或斜展排成总状花序或复总状花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_rutifolia_Steph_ex_Spreng"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根本质根状茎粗短木质有多数营养枝"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#半灌木状草本有时成小灌木状"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面被灰白色平贴丝状短柔毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#具脱落性的枇糠状或鳞片状托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花5_10朵花冠狭圆锥状或狭管状檐部2_3裂齿两性花12_15朵孕育花冠檐部外面微有短柔毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层与中层卵形或长卵形背面有白色丝状短柔毛内层椭圆形或卵形背面近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>香叶蒿</art:中文名>
    <rdfs:label>香叶蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#多花蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#云南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#贵州省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#消炎蚕豆发芽的催芽剂云南民间"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶长圆形或卵形二回羽状深裂或近全裂每侧裂片4_5_6枚小裂片椭圆状披针形或线状披针形宽3_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#卵形直径1_5_2mm无梗或具短梗排成穗状花序在茎上组成开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_myriantha_Wall_ex_Bess"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根状茎短"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面疏被短柔毛及短腺毛或近无毛背面被灰白色蛛丝状绒毛脉上被腺毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#具托毛_原文未明确"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花4_8朵花冠狭管状或狭圆锥状檐部2裂齿两性花6_12朵孕育花冠管状"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外中层卵形或长卵形背面近无毛或初时被短柔毛后脱落"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#多花蒿系"/>
    <art:中文名>多花蒿</art:中文名>
    <rdfs:label>多花蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#主根单一垂直狭纺锤状">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
