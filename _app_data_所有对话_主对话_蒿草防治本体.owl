    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层披针形或卵形中内层卵形外中层背面微被灰白色平贴短柔毛边膜质内层半膜质背面近无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
