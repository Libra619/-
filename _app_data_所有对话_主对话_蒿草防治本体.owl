    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部叶卵形一至二回羽状分裂第一回全裂第二回为栉齿状深裂齿裂齿先端圆钝具腺体中部与上部叶羽状浅裂或不分裂线形半肉质"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#球形或半球形直径3_5mm有短梗或近无梗下垂排成开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_succulentoides_Ling_et_Y_R_Ling"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根单一细垂直"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#一二年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#初时被短柔毛并疏被腺毛后毛渐脱落"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#密生白色托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花5_20朵花冠狭圆锥状或狭管状檐部3_2裂齿两性花30_50朵孕育花冠管状外面有稀疏腺点檐部外面有白色柔毛"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层内层近等长外层与中层卵形或狭卵形背面被灰白色短柔毛内层椭圆形或长卵形"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>肉质叶蒿</art:中文名>
    <rdfs:label>肉质叶蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#臭蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#云南省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#四川省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#青海省"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#清热解毒凉血消炎除湿杀虫药"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#基生叶多数密集成莲座状长椭圆形二回栉齿状羽状分裂每侧裂片20余枚茎下部与中部叶长椭圆形二回栉齿状羽状分裂第一回全裂每侧裂片5_10枚小裂片两侧密被细小锐尖栉齿齿长2_3mm宽0_2_1mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形或近球形直径3_4_5mm排成密集狭窄圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_hedini_Ostenf_et_Pauls"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根单一垂直"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#一年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#叶绿色背面微被腺毛状短柔毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起半球形"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花3_8朵花冠狭圆锥状或狭管状檐部2_3裂齿两性花15_30朵孕育花冠管状檐部紫红色外面有腺点"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3层内层近等长外层椭圆形或披针形背面无毛或微有腺毛状短柔毛边缘紫褐色或深褐色膜质中内层椭圆形或卵形近膜质或膜质无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>臭蒿</art:中文名>
    <rdfs:label>臭蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#青蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#清热凉血退蒸解暑祛风止痒无抗疟作用"/>
    <art:包含成分 rdf:resource="http://www.example.org/ontology/Artemisia#含艾蒿碱及苦味素不含青蒿素"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶二回栉齿状羽状分裂中轴及羽轴两侧有栉齿小裂片线形"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序半球形直径3_5_4_5毫米"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_carvifolia"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#主根单一垂直"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#一或二年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#两面无毛"/>
    <art:致敏物质是 rdf:resource="http://www.example.org/ontology/Artemisia#花粉"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#球形无托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花10_20朵两性花30_40朵均结实"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#外层总苞片长卵形背面绿色无毛有细小白点边缘宽膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#艾蒿组"/>
    <art:中文名>青蒿</art:中文名>
    <rdfs:label>青蒿</rdfs:label>
  </rdf:Description>
