    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#茎枝叶两面被绒毛或初时被短柔毛后渐稀疏脱落无毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花6_10朵花冠狭管状或狭圆锥状檐部2_3裂齿两性花6_10朵不孕育花冠管状花柱短先端棒状2裂不叉开退化子房小"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层卵形或长卵形背面无毛或初时微有短柔毛边缘膜质内层长卵形或椭圆形半膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#龙蒿组"/>
    <art:中文名>龙蒿</art:中文名>
    <rdfs:label>龙蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#Artemisia_anomala_var_tomentella_Hand_Mazz">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
