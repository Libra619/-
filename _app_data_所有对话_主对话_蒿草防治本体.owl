    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#内蒙古自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#吉林省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#宁夏回族自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#山西省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#新疆维吾尔自治区"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#甘肃省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#辽宁省"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#黑龙江省"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#蒙药祛风除湿止痛"/>
    <art:包含成分 rdf:resource="http://www.example.org/ontology/Artemisia#含挥发油主要成分为醛类还含生物碱"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#茎下部中部叶卵形或宽卵形一至二回羽状全裂每侧裂片2_4枚小裂片线形宽1_5_2mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#卵形直径3_4mm具短梗排成穗状花序或总状花序在茎上组成开展圆锥花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_halodendron_Turcz_ex_Bess"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根粗壮木质根状茎粗大木质"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#小灌木"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#幼时微被短柔毛后无毛"/>
    <art:特殊特征是 rdf:resource="http://www.example.org/ontology/Artemisia#固沙植物"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#凸起"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花4_10朵花冠狭管状两性花8_20朵不孕育"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片3_4层外层卵形或长卵形背面无毛或微被短柔毛边缘膜质"/>
    <art:造成危害 rdf:resource="http://www.example.org/ontology/Artemisia#土壤退化"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#龙蒿组"/>
    <art:中文名>盐蒿</art:中文名>
    <rdfs:label>盐蒿</rdfs:label>
  </rdf:Description>
