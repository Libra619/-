  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#球形直径2_5_3mm有短梗或近无梗单生或2_3枚集生排成总状或穗状花序在茎上组成开展略伸长圆锥花序">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
