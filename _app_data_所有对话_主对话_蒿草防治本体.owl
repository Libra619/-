    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序较大直径4_5_7mm总苞片开花后成放射状开张花易于脱落"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_carvifolia_var_schochii_Mattf_Pamp"/>
