  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#冻原白蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:分布于 rdf:resource="http://www.example.org/ontology/Artemisia#西藏自治区"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#基生叶与茎下部叶狭长卵形长圆形或长椭圆形二至三回羽状全裂小裂片狭线状披针形或线形宽1_1_5mm"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形直径6_10mm有短梗下垂排成总状花序或密穗状花序式总状花序"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_stracheyi_Hook_f_et_Thoms_ex_C_B_Clarke"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#根木质粗大根状茎粗短木质直径约3_4cm常有老茎残基与基生叶的叶柄残基"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#茎叶两面及总苞片背面密被灰黄色或淡黄色绢质绒毛"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#半球形具稀疏脱落性托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花4_10朵花冠管状或狭管状檐部2_3裂齿外面粘附淡黄色脱落性长绒毛两性花50_60朵花冠管状外面粘附多数淡黄色脱落性长绒毛雄蕊线形花柱略比花冠管短先端微叉开"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片4层外层卵形或长卵形中层长卵形或椭圆形边缘宽膜质褐色内层椭圆形或匙形半膜质"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#莳萝蒿组"/>
    <art:中文名>冻原白蒿</art:中文名>
    <rdfs:label>冻原白蒿</rdfs:label>
  </rdf:Description>
