  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#半球形直径3_4_5mm有短梗及小苞叶下垂或斜生排成穗状花序式总状花序或复总状花序在茎上组成略开展或狭长圆锥花序">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
