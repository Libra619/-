  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#萎蒿">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.example.org/ontology/Artemisia#种"/>
    <art:功效是 rdf:resource="http://www.example.org/ontology/Artemisia#止血消炎镇咳化痰治肝炎"/>
    <art:叶形态是 rdf:resource="http://www.example.org/ontology/Artemisia#中部叶近成掌状5深裂或指状3深裂裂片线状披针形边缘有细锯齿"/>
    <art:头状花序特征是 rdf:resource="http://www.example.org/ontology/Artemisia#头状花序长圆形直径2_2_5毫米"/>
    <art:拉丁名是 rdf:resource="http://www.example.org/ontology/Artemisia#Artemisia_selengensis"/>
    <art:根状茎特征是 rdf:resource="http://www.example.org/ontology/Artemisia#具匍匐地下茎"/>
    <art:植株类型是 rdf:resource="http://www.example.org/ontology/Artemisia#多年生草本"/>
    <art:毛被腺体是 rdf:resource="http://www.example.org/ontology/Artemisia#上面无毛背面密被灰白色蛛丝状绵毛"/>
    <art:特殊特征是 rdf:resource="http://www.example.org/ontology/Artemisia#可生于水中"/>
    <art:致敏物质是 rdf:resource="http://www.example.org/ontology/Artemisia#花粉"/>
    <art:花序托是 rdf:resource="http://www.example.org/ontology/Artemisia#小凸起无托毛"/>
    <art:花结构与育性是 rdf:resource="http://www.example.org/ontology/Artemisia#雌花8_12朵两性花10_15朵均结实"/>
    <art:苞片特征是 rdf:resource="http://www.example.org/ontology/Artemisia#总苞片背面初时疏被蛛丝状短绵毛后无毛"/>
    <art:隶属于 rdf:resource="http://www.example.org/ontology/Artemisia#萎蒿系"/>
    <art:中文名>萎蒿</art:中文名>
    <rdfs:label>萎蒿</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.example.org/ontology/Artemisia#茎中部叶卵圆形一至二回羽状全裂小裂片狭线形宽0_5_1mm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
